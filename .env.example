# =============================================================================
# Daedalus — Shared environment file
# Copy to `.env` at repository root and adjust values.
# Loaded automatically by docker-compose via `env_file: .env`.
# =============================================================================

# --- Postgres (project-service, auth-service) ---
POSTGRES_USER=daedalus
POSTGRES_PASSWORD=daedalus
POSTGRES_DB=daedalus
POSTGRES_PORT=5432

# DSN consumed by Go services
DB_DSN=postgres://daedalus:daedalus@postgres:5432/daedalus?sslmode=disable

# --- Service ports (kept aligned with prometheus.yml) ---
PROJECT_SERVICE_PORT=8080
AUTH_SERVICE_PORT=8081
PAYMENT_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
ORCHESTRATOR_PORT=8084
PROCUREMENT_PORT=8085
LAYOUT_PORT=8086
ASSET_3D_PORT=8087
ANALYTICS_PORT=8088

# --- Auth (SRS §6.1) ---
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --- Payments (SRS §3.4) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Messaging / cache ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=daedalus.events
REDIS_URL=redis://redis:6379/0

# --- Object storage (MinIO) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=daedalus-assets

# --- External AI / 3D providers ---
MESHY_API_KEY=
GEMINI_API_KEY=

# --- Mail (notification-service) ---
MAILGUN_DOMAIN=
MAILGUN_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_AUTH_URL=http://localhost:8081
